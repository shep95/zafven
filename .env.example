# Copy to ".env" locally, or set these as Variables in the Railway dashboard.

# ── Required ──────────────────────────────────────────────────────────────
DISCORD_TOKEN=your-discord-bot-token
GEMINI_API_KEY=your-gemini-api-key

# ── Gemini LLM (https://ai.google.dev) ───────────────────────────────────
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_TOKENS=1200
GEMINI_TIMEOUT=45
# "auto"/"on" enable Google Search grounding; "off" disables it.
GEMINI_WEB_SEARCH=auto

# ── Paywall / premium ─────────────────────────────────────────────────────
# Reading commands require a premium role, a Discord subscription, or admin.
PREMIUM_ROLES=Premium
# Optional: Discord monetization SKU id for native app subscriptions.
PREMIUM_SKU_ID=
# Admins / guild owner bypass the paywall (handy for testing).
PREMIUM_BYPASS_ADMIN=true
# Optional external subscribe link (Patreon/Ko-fi/etc.) shown on the upsell.
SUBSCRIBE_URL=

# ── Discord behaviour ─────────────────────────────────────────────────────
GUILD_ID=
MEMBER_LOG_CHANNEL=member-log
PROTECTED_ROLES=Admin,Moderator,Mod,Booster
DEFAULT_INACTIVE_DAYS=30
ACTIVITY_SCAN_LIMIT=2000
JOIN_GRACE_DAYS=7

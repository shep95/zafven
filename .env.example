# Copy to ".env" locally, or set these as Variables in the Railway dashboard.

# ── Required ──────────────────────────────────────────────────────────────
DISCORD_TOKEN=your-discord-bot-token
GEMINI_API_KEY=your-gemini-api-key

# ── Gemini LLM (https://ai.google.dev) ───────────────────────────────────
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_TOKENS=1200
GEMINI_TIMEOUT=45
# 0 disables model "thinking" (recommended — stops replies cutting off mid-sentence).
GEMINI_THINKING_BUDGET=0
# "auto"/"on" enable Google Search grounding; "off" disables it.
GEMINI_WEB_SEARCH=auto
# How much Gemini's own filter blocks: BLOCK_NONE (loosest) / BLOCK_ONLY_HIGH /
# BLOCK_MEDIUM_AND_ABOVE / BLOCK_LOW_AND_ABOVE. "OFF" = BLOCK_NONE.
GEMINI_SAFETY=BLOCK_ONLY_HIGH
# Voice (Gemini text-to-speech). Voice names: Kore, Puck, Aoede, Leda, Zephyr, …
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_TTS_VOICE=Kore
# Two-way voice speed knobs. Lower silence = snappier (too low cuts you off).
VOICE_SILENCE_MS=700
VOICE_MIN_MS=450
VOICE_REPLY_TOKENS=120
VOICE_MODEL=gemini-2.0-flash

# ── File / image safety scanning ──────────────────────────────────────────
FILESCAN_ENABLED=true
# Classify images for NSFW via Gemini vision (one API call per image).
NSFW_SCAN_ENABLED=true
NSFW_ALLOW_IN_NSFW_CHANNELS=true
# Extra blocked file extensions (added to the built-in executable/script list).
BLOCKED_EXTENSIONS=
# Optional: known-malware hash lookups (no file is uploaded, just its hash).
VIRUSTOTAL_API_KEY=
FILESCAN_MAX_IMAGE_MB=8
FILESCAN_BYPASS_MODS=false

# ── Anti-manipulation / scam-tactic callouts ──────────────────────────────
ANTIMANIP_ENABLED=true
MOD_ALERT_CHANNEL=mod-alerts
# Roles @mentioned on every mod alert / report (comma-separated role names).
MOD_ROLES=Moderator,Admin,Mod
ANTIMANIP_BYPASS_MODS=true

# ── Anti-cyberbullying (warn once, then mute) ─────────────────────────────
HARASS_FILTER_ENABLED=true
HARASS_MUTE_SECONDS=1800
HARASS_WARN_WINDOW_SECONDS=3600
HARASS_BYPASS_MODS=true

# ── Profanity filter ──────────────────────────────────────────────────────
PROFANITY_FILTER_ENABLED=true
# Curse words per message before the bot acts (1 = censor any).
PROFANITY_THRESHOLD=1
# "censor" = delete + repost a starred version; "delete" = delete + brief warning.
PROFANITY_ACTION=censor
# Extra words to censor (comma-separated), added to the built-in list.
PROFANITY_EXTRA_WORDS=
# Members with Manage Messages are exempt when true.
PROFANITY_BYPASS_MODS=true

# ── Anti-spam / anti-scam ─────────────────────────────────────────────────
ANTISPAM_ENABLED=true
ANTISPAM_FLOOD_COUNT=5
ANTISPAM_FLOOD_SECONDS=7
ANTISPAM_DUPLICATE_COUNT=3
ANTISPAM_MAX_MENTIONS=5
ANTISPAM_BLOCK_INVITES=true
ANTISPAM_TIMEOUT_SECONDS=300
ANTISPAM_BYPASS_MODS=true

# ── Discord behaviour ─────────────────────────────────────────────────────
GUILD_ID=
WELCOME_CHANNEL=welcome
MEMBER_LOG_CHANNEL=member-log
# Deleted-message audit log (mods only). Needs the bot to have View Audit Log.
DELETED_LOG_CHANNEL=message-log
MESSAGE_LOG_ENABLED=true
PROTECTED_ROLES=Admin,Moderator,Mod,Booster
# Members with this role can't be read by /profile.
PROFILE_OPTOUT_ROLES=no-readings

# ── Live chat personality (Zafven, she/her) ───────────────────────────────
CHAT_ENABLED=true
# 0.0 = only reply when @mentioned or replied to. 0.05 = ~5% ambient chime-ins.
CHAT_AMBIENT_CHANCE=0.0
CHAT_COOLDOWN_SECONDS=6
CHAT_CONTEXT_MESSAGES=12
# Limit chatting to these channel names (comma-separated). Empty = everywhere.
CHAT_CHANNELS=

# ── YouTube + knowledge reports ───────────────────────────────────────────
# Optional: real video search for /youtube (else AI-suggested links).
YOUTUBE_API_KEY=
# Public channel where /learn posts knowledge reports.
KNOWLEDGE_CHANNEL=knowledge

# ── Phase 2: persistence + scheduled/stateful features ────────────────────
# Hidden channel for persistent data (XP, time capsules, ciphers).
DATA_CHANNEL=zafven-data
RANKS_ENABLED=true
RANK_COOLDOWN_SECONDS=60
RANK_LADDER=Seeker:1,Initiate:3,Adept:6,Mystic:10,Oracle:15
DAILY_ENABLED=true
DAILY_CHANNEL=oracle
DAILY_HOUR_UTC=13
DEFAULT_INACTIVE_DAYS=30
ACTIVITY_SCAN_LIMIT=2000
JOIN_GRACE_DAYS=7
